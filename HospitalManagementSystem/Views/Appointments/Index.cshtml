@model IEnumerable<HospitalManagementSystem.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="card shadow">

    <div class="card-header bg-warning">

        <div class="row align-items-center">

            <div class="col-md-4">
                <h4 class="mb-0">
                    <i class="fa-solid fa-calendar-check"></i> Appointments
                </h4>
            </div>

            <div class="col-md-4">
                <input type="text"
                       id="searchAppointment"
                       class="form-control"
                       placeholder="🔍 Search Appointment..." />
            </div>

            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-dark">
                    <i class="fa-solid fa-plus"></i> Add Appointment
                </a>
            </div>

        </div>

    </div>

    <div class="card-body">

        <table class="table table-striped table-hover table-bordered align-middle"
               id="appointmentTable">

            <thead class="table-dark">
                <tr>
                    <th>Patient ID</th>
                    <th>Patient Name</th>
                    <th>Doctor ID</th>
                    <th>Doctor Name</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th width="220">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.PatientId</td>
                        <td>@item.Patient?.FullName</td>

                        <td>@item.DoctorId</td>
                        <td>@item.Doctor?.DoctorName</td>

                        <td>@item.AppointmentDate.ToShortDateString()</td>
                        <td>@item.AppointmentTime</td>

                        <td>@item.Reason</td>

                        <td>@item.Status</td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.AppointmentId"
                               class="btn btn-warning btn-sm">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.AppointmentId"
                               class="btn btn-info btn-sm text-white">
                                <i class="fa-solid fa-eye"></i>
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.AppointmentId"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this appointment?');">
                                <i class="fa-solid fa-trash"></i>
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section Scripts
{
    <script>

        document.getElementById("searchAppointment").addEventListener("keyup", function () {

            var value = this.value.toLowerCase();

            var rows = document.querySelectorAll("#appointmentTable tbody tr");

            rows.forEach(function (row) {

                row.style.display = row.innerText.toLowerCase().includes(value)
                    ? ""
                    : "none";

            });

        });

    </script>
}