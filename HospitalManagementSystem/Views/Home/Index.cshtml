@model HospitalManagementSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

<div class="row">

    <div class="col-md-3 mb-4">
        <div class="card bg-primary text-white shadow">
            <div class="card-body text-center">
                <i class="fa-solid fa-user fa-3x mb-3"></i>

                <h5>Total Patients</h5>

                <h2>@Model.TotalPatients</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card bg-success text-white shadow">
            <div class="card-body text-center">
                <i class="fa-solid fa-user-doctor fa-3x mb-3"></i>

                <h5>Total Doctors</h5>

                <h2>@Model.TotalDoctors</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card bg-warning text-dark shadow">
            <div class="card-body text-center">
                <i class="fa-solid fa-calendar-check fa-3x mb-3"></i>

                <h5>Total Appointments</h5>

                <h2>@Model.TotalAppointments</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card bg-danger text-white shadow">
            <div class="card-body text-center">
                <i class="fa-solid fa-money-bill-wave fa-3x mb-3"></i>

                <h5>Total Revenue</h5>

                <h2>₹ @Model.TotalRevenue</h2>
            </div>
        </div>
    </div>

</div>