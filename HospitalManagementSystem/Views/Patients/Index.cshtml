@model IEnumerable<HospitalManagementSystem.Models.Patient>

@{
    ViewData["Title"] = "Patients";
}
<div class="card shadow">
<div class="card-header bg-primary text-white">

    <div class="row align-items-center">

        <div class="col-md-4">
            <h4 class="mb-0">
                <i class="fa-solid fa-users"></i> Patients
            </h4>
        </div>

        <div class="col-md-4">
            <input type="text"
                   id="searchPatient"
                   class="form-control"
                   placeholder="🔍 Search Patient..." />
        </div>

        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-light">
                <i class="fa-solid fa-user-plus"></i> Add Patient
            </a>
        </div>

    </div>

</div>

    <div class="card-body">
 

    <table class="table table-striped table-hover table-bordered align-middle"
           id="patientTable">

            <thead class="table-dark">

                <tr>
                    <th>Full Name</th>
                    <th>Age</th>
                    <th>Gender</th>
                    <th>Phone</th>
                    <th>Disease</th>
                    <th width="220">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.FullName</td>
                        <td>@item.Age</td>
                        <td>@item.Gender</td>
                        <td>@item.Phone</td>
                        <td>@item.Disease</td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.PatientId"
                               class="btn btn-warning btn-sm">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.PatientId"
                               class="btn btn-info btn-sm text-white">
                                <i class="fa-solid fa-eye"></i>
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.PatientId"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this patient?');">
                                <i class="fa-solid fa-trash"></i>
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
@section Scripts
{
    <script>
        alert("Script Loaded");

        document.getElementById("searchPatient").addEventListener("keyup", function () {

            alert("Typing");

            var value = this.value.toLowerCase();

            var rows = document.querySelectorAll("#patientTable tbody tr");

            rows.forEach(function (row) {
                row.style.display = row.innerText.toLowerCase().includes(value)
                    ? ""
                    : "none";
            });

        });
    </script>
}