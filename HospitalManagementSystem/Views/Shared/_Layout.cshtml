@using Microsoft.AspNetCore.Http
<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Hospital Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>

<body>

    <div class="d-flex">

        <!-- Sidebar -->
        <div class="bg-dark text-white p-3 vh-100" style="width:260px;">

            <h3 class="text-center mb-4">
                🏥 HMS
            </h3>

            <a asp-controller="Home" asp-action="Index"
               class="btn btn-dark w-100 text-start mb-2">
                <i class="fa-solid fa-house"></i> Dashboard
            </a>

            <a asp-controller="Patients" asp-action="Index"
               class="btn btn-dark w-100 text-start mb-2">
                <i class="fa-solid fa-user"></i> Patients
            </a>

            @if (Context.Session.GetString("Role") == "Admin")
            {
                <a asp-controller="Doctors" asp-action="Index"
                   class="btn btn-dark w-100 text-start mb-2">
                    <i class="fa-solid fa-user-doctor"></i> Doctors
                </a>
            }

            <a asp-controller="Appointments" asp-action="Index"
               class="btn btn-dark w-100 text-start mb-2">
                <i class="fa-solid fa-calendar"></i> Appointments
            </a>

            @if (Context.Session.GetString("Role") == "Admin")
            {
                <a asp-controller="Billings"
                   asp-action="Index"
                   class="btn btn-dark w-100 text-start mb-2">
                    <i class="fa-solid fa-money-bill"></i> Billing
                </a>
            }

        </div>

        <!-- Main Content -->
        <div class="flex-grow-1">

            <!-- Navbar -->
            <nav class="navbar navbar-dark bg-primary shadow">
                <div class="container-fluid">

                    <span class="navbar-brand">
                        Hospital Management System
                    </span>

                    <div class="d-flex align-items-center">

                        <span class="text-white me-3">
                            Welcome @Context.Session.GetString("Username")
                            (@Context.Session.GetString("Role")) 👋
                        </span>

                        <a asp-controller="Account"
                           asp-action="Logout"
                           class="btn btn-danger btn-sm">
                            <i class="fa-solid fa-right-from-bracket"></i> Logout
                        </a>

                    </div>
                </div>
            </nav>

            <div class="container-fluid mt-4">

                @RenderBody()

            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)




</body>
</html>
