@model IEnumerable<HospitalManagementSystem.Models.Billing>

@{
    ViewData["Title"] = "Billing";
}

<div class="card shadow">

    <div class="card-header bg-success text-white">

        <div class="row align-items-center">

            <div class="col-md-4">
                <h4 class="mb-0">
                    <i class="fa-solid fa-money-bill-wave"></i> Billing
                </h4>
            </div>

            <div class="col-md-4">
                <input type="text"
                       id="searchBilling"
                       class="form-control"
                       placeholder="🔍 Search Billing..." />
            </div>

            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-light">
                    <i class="fa-solid fa-plus"></i> Add Bill
                </a>
            </div>

        </div>

    </div>

    <div class="card-body">

        <table class="table table-striped table-hover table-bordered align-middle"
               id="billingTable">

            <thead class="table-dark">
                <tr>
                    <th>Appointment ID</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Consultation</th>
                    <th>Lab</th>
                    <th>Medicine</th>
                    <th>Other</th>
                    <th>Total</th>
                    <th>Date</th>
                    <th width="280">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.AppointmentId</td>

                        <td>@item.Appointment?.Patient?.FullName</td>

                        <td>@item.Appointment?.Doctor?.DoctorName</td>

                        <td>₹ @item.ConsultationFee</td>

                        <td>₹ @item.LabFee</td>

                        <td>₹ @item.MedicineFee</td>

                        <td>₹ @item.OtherCharges</td>

                        <td>
                            <span class="badge bg-success fs-6">
                                ₹ @item.TotalAmount
                            </span>
                        </td>

                        <td>@item.BillDate.ToShortDateString()</td>

                        <td>

                            <a asp-action="Invoice"
                               asp-route-id="@item.BillId"
                               class="btn btn-success btn-sm">
                                <i class="fa-solid fa-file-invoice"></i>
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.BillId"
                               class="btn btn-warning btn-sm">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.BillId"
                               class="btn btn-info btn-sm text-white">
                                <i class="fa-solid fa-eye"></i>
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.BillId"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this bill?');">
                                <i class="fa-solid fa-trash"></i>
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section Scripts
{
    <script>

        document.getElementById("searchBilling").addEventListener("keyup", function () {

            var value = this.value.toLowerCase();

            var rows = document.querySelectorAll("#billingTable tbody tr");

            rows.forEach(function (row) {

                row.style.display = row.innerText.toLowerCase().includes(value)
                    ? ""
                    : "none";

            });

        });

    </script>
}